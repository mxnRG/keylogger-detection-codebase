# ML-first FYP demo — alerts from eBPF telemetry + ensemble models only.
# No process-name / cmdline simulator scan (set FYP_DEMO_PROFILE=safe for sim-assist).

export FYP_DEMO_VERBOSE="${FYP_DEMO_VERBOSE:-1}"
export FYP_ML_DEEP_LOG="${FYP_ML_DEEP_LOG:-1}"

export FYP_ARTIFACT_RUN="${FYP_ARTIFACT_RUN:-/home/fyp/project/artifacts/run_20260531_l2_hybrid}"
export FYP_ML_CALIBRATE_SAMPLES="${FYP_ML_CALIBRATE_SAMPLES:-20}"

# All levels participate in ML detection (do not ignore L2)
export FYP_ML_IGNORE_LEVELS="${FYP_ML_IGNORE_LEVELS:-}"

export FYP_ML_L2_THRESHOLD="${FYP_ML_L2_THRESHOLD:-0.35}"
export FYP_ML_L3_THRESHOLD="${FYP_ML_L3_THRESHOLD:-0.40}"
export FYP_ML_L2_DELTA="${FYP_ML_L2_DELTA:-0.25}"
export FYP_ML_L3_DELTA="${FYP_ML_L3_DELTA:-0.18}"

# L2 syscall spikes (openat+read) — telemetry-based, good for device-scan L2 sims
export FYP_ML_L2_SPIKES="${FYP_ML_L2_SPIKES:-1}"
export FYP_ML_L3_SPIKES="${FYP_ML_L3_SPIKES:-0}"
export FYP_ML_L3_ROLLING="${FYP_ML_L3_ROLLING:-0}"
export FYP_ML_L4_SPIKES="${FYP_ML_L4_SPIKES:-0}"

# Process scan OFF — not used for alerts in this profile
export FYP_ML_SIM_DETECT="${FYP_ML_SIM_DETECT:-0}"
export FYP_ML_SIM_MALICIOUS_STREAK="${FYP_ML_SIM_MALICIOUS_STREAK:-1}"

# Spikes apply on syscall telemetry (no sim required)
export FYP_ML_SPIKES_REQUIRE_SIM="${FYP_ML_SPIKES_REQUIRE_SIM:-0}"

export FYP_ML_MALICIOUS_STREAK="${FYP_ML_MALICIOUS_STREAK:-3}"
export FYP_ML_RULE_STREAK="${FYP_ML_RULE_STREAK:-1}"
export FYP_ML_HOLD_TICKS="${FYP_ML_HOLD_TICKS:-8}"
export FYP_ML_BENIGN_STREAK="${FYP_ML_BENIGN_STREAK:-3}"

export FYP_ML_L2_SPIKE_STREAK="${FYP_ML_L2_SPIKE_STREAK:-2}"
export FYP_ML_L3_SPIKE_STREAK="${FYP_ML_L3_SPIKE_STREAK:-2}"
export FYP_ML_L2_OPENAT_MARGIN="${FYP_ML_L2_OPENAT_MARGIN:-2200}"
export FYP_ML_L2_READ_MARGIN="${FYP_ML_L2_READ_MARGIN:-2800}"
